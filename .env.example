# ============================================================
# Environment template for nyc-taxi-elt
# Copy this file to .env and fill in real values
# Never commit .env to version control
# ============================================================

# --- Airflow Docker setup ---
AIRFLOW_UID=50000
_PIP_ADDITIONAL_REQUIREMENTS=apache-airflow-providers-snowflake==5.7.1 dbt-snowflake==1.8.4 boto3==1.35.0 requests==2.32.3

# --- Snowflake connection (used by Airflow + dbt in later phases) ---
SNOWFLAKE_ACCOUNT=<your-account>.us-west-2          # e.g., abc12345.us-west-2
SNOWFLAKE_USER=ELT_USER
SNOWFLAKE_PASSWORD=<your-password>
SNOWFLAKE_ROLE=ELT_ROLE
SNOWFLAKE_WAREHOUSE=WH_ELT
SNOWFLAKE_DATABASE=NYC_TAXI
SNOWFLAKE_SCHEMA=RAW

# --- AWS credentials (used by ingestion code in Phase 2) ---
AWS_ACCESS_KEY_ID=<your-access-key>
AWS_SECRET_ACCESS_KEY=<your-secret-key>
AWS_REGION=us-west-2
S3_BUCKET=<your-bucket-name>
